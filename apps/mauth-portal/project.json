{
  "name": "mauth-portal",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mauth-portal/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mauth-portal",
        "command": "vite build"
      },
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{workspaceRoot}/dist/mauth-portal"]
    },
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mauth-portal",
        "command": "vite"
      }
    },
    "preview": {
      "continuous": true,
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "apps/mauth-portal",
        "command": "vite preview"
      }
    },
    "dev": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mauth-portal",
        "command": "vite"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mauth-portal",
        "command": "tsc --noEmit -p tsconfig.app.json"
      },
      "cache": true,
      "inputs": ["production", "^production"]
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "mauth-portal:build",
        "spa": true
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mauth-portal",
        "command": "eslint ."
      },
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/mauth-portal",
        "command": "vitest"
      },
      "cache": true
    }
  }
}
